// ============================================
// 鹰爪技能 · 入口文件
// ============================================
//
// 启动流程：
// 1. 加载环境变量
// 2. 校验配置
// 3. 注册技能
// 4. 启动 Agent
//
// ============================================

import 'dotenv/config';
import { loadKeyPair, generateKeyPair } from './identity.js';
import { registry } from './skills/registry.js';
import { webSearchSkill } from './skills/web-search.js';
import { codeRunnerSkill } from './skills/code-runner.js';
import { fileIoSkill } from './skills/file-io.js';
import { llmCallSkill } from './skills/llm-call.js';
import { Agent } from './agent.js';
import type { AgentConfig } from './types.js';

// ==========================================
// 1. 配置校验
// ==========================================

function loadConfig(): AgentConfig {
  let privateKey = process.env.NODE_PRIVATE_KEY || '';
  let publicKey = process.env.NODE_PUBLIC_KEY || '';

  // 如果没有配置密钥，自动生成（开发模式）
  if (!privateKey) {
    console.log('[INIT] ⚠️ No NODE_PRIVATE_KEY found, generating ephemeral key pair...');
    console.log('[INIT] ⚠️ This key will change on restart. For production, run: npm run keygen');
    const kp = generateKeyPair();
    privateKey = kp.privateKey;
    publicKey = kp.publicKey;
  } else {
    // 从私钥推导公钥（确保一致）
    const kp = loadKeyPair(privateKey);
    publicKey = kp.publicKey;
  }

  const config: AgentConfig = {
    httpUrl: process.env.SKYNET_HTTP_URL || 'http://localhost:9000',
    wsUrl: process.env.SKYNET_WS_URL || 'ws://localhost:9000/ws',
    privateKey,
    publicKey,
    alias: process.env.NODE_ALIAS || `eagle-${publicKey.slice(0, 8)}`,
    pollInterval: parseInt(process.env.AGENT_POLL_INTERVAL || '10', 10),
    enabledSkills: (process.env.ENABLED_SKILLS || '')
      .split(',')
      .map(s => s.trim())
      .filter(Boolean),
  };

  return config;
}

// ==========================================
// 2. 注册技能
// ==========================================

function registerSkills(enabledSkills: string[]): void {
  console.log('[INIT] Registering skills...');

  const allSkills = [
    webSearchSkill,
    codeRunnerSkill,
    fileIoSkill,
    // llm-call 最后注册（优先级最低，万能兜底）
    llmCallSkill,
  ];

  for (const skill of allSkills) {
    // 如果配置了白名单，只注册白名单中的技能
    if (enabledSkills.length > 0 && !enabledSkills.includes(skill.name)) {
      console.log(`[INIT] Skipping skill: ${skill.name} (not in ENABLED_SKILLS)`);
      continue;
    }
    registry.register(skill);
  }

  console.log(`[INIT] ${registry.getAll().length} skill(s) registered`);
  console.log('');
}

// ==========================================
// 3. 启动
// ==========================================

async function main(): Promise<void> {
  console.log('');
  console.log('  🦅 鹰爪技能 · Eagle Claw Skills v1.0.0');
  console.log('  ─────────────────────────────────────────');
  console.log('');

  // 加载配置
  const config = loadConfig();

  // 注册技能
  registerSkills(config.enabledSkills);

  // 创建并启动 Agent
  const agent = new Agent(config);

  // 优雅退出
  const shutdown = async (signal: string) => {
    console.log(`\n[INIT] Received ${signal}, shutting down gracefully...`);
    await agent.stop();
    process.exit(0);
  };

  process.on('SIGINT', () => shutdown('SIGINT'));
  process.on('SIGTERM', () => shutdown('SIGTERM'));

  // 未捕获异常处理
  process.on('uncaughtException', (err) => {
    console.error('[FATAL] Uncaught exception:', err);
    agent.printStats();
    process.exit(1);
  });

  process.on('unhandledRejection', (reason) => {
    console.error('[FATAL] Unhandled rejection:', reason);
  });

  // 启动
  await agent.start();

  // 保持进程运行
  // Agent 内部的 setInterval + WebSocket 会保持事件循环活跃
}

main().catch((err) => {
  console.error('[FATAL] Startup failed:', err);
  process.exit(1);
});
