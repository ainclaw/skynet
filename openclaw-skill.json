{
  "name": "eagle-claw",
  "version": "2.1.1",
  "description": "鹰爪(Eagle Claw) - 星联分布式任务执行节点",
  "author": "EagleClaw Team",
  "install": {
    "command": "npm",
    "args": ["install", "--include=dev"]
  },
  "build": {
    "command": "npm",
    "args": ["run", "build"]
  },
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["dist/index.js", "--mcp"]
  },
  "tools": [
    "eagle_claw_connect",
    "eagle_claw_status",
    "eagle_claw_execute",
    "eagle_claw_disconnect"
  ],
  "config_schema": {
    "SKYNET_WS_URL": {
      "type": "string",
      "default": "ws://localhost:8080",
      "description": "星联调度服务器 WebSocket 地址"
    },
    "OPENCLAW_API_URL": {
      "type": "string",
      "default": "http://localhost:3000",
      "description": "本地 OpenClaw 引擎 API 地址"
    },
    "PRIVATE_KEY": {
      "type": "string",
      "default": "",
      "description": "Ed25519 私钥(Base64编码)，留空则自动生成临时身份"
    }
  }
}
