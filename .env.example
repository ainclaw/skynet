# ============================================
# 鹰爪技能 · 环境变量配置
# ============================================

# 天网中枢地址
SKYNET_HTTP_URL=http://localhost:9000
SKYNET_WS_URL=ws://localhost:9000/ws

# 节点身份（首次运行 npm run keygen 自动生成）
NODE_PRIVATE_KEY=
NODE_PUBLIC_KEY=
NODE_ALIAS=eagle-node-01

# 大模型配置（技能：llm-call）
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# 代码执行沙箱超时（秒）
CODE_EXEC_TIMEOUT=30

# Agent 轮询间隔（秒）
AGENT_POLL_INTERVAL=10

# 技能白名单（逗号分隔，留空=全部启用）
ENABLED_SKILLS=web-search,code-runner,file-io,llm-call

# 可选：SearXNG 私有搜索实例
# SEARXNG_URL=http://localhost:8080
