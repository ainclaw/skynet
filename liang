// ============================================
// 鹰爪技能 · AI Agent 主循环
// ============================================
//
// Agent 生命周期：
// 1. 启动 → 注册节点 → 连接 WebSocket
// 2. 主循环：
//    a. 轮询 open 状态的任务
//    b. 用技能注册表匹配可处理的任务
//    c. 抢单 → 执行技能 → 提交结果
// 3. 同时监听 WebSocket 推送，实时响应新任务
//
// 并发控制：同一时间只处理一个任务（串行）
// 后续可扩展为并发池
//
// ============================================

import { mkdir } from 'node:fs/promises';
import { join } from 'node:path';
import { SkynetClient } from './client.js';
import { registry } from './skills/registry.js';
import type { AgentConfig, Task, SkillContext, WsEvent } from './types.js';

export class Agent {
  private client: SkynetClient;
  private config: AgentConfig;
  private running = false;
  private processing = false; // 是否正在处理任务
  private pollTimer: ReturnType<typeof setInterval> | null = null;
  private workBaseDir: string;

  // 统计
  private stats = {
    tasksProcessed: 0,
    tasksSucceeded: 0,
    tasksFailed: 0,
    totalReward: 0,
    startTime: Date.now(),
  };

  constructor(config: AgentConfig) {
    this.config = config;
    this.client = new SkynetClient(config);
    this.workBaseDir = join(process.cwd(), '.eagle-work');
  }

  /** 启动 Agent */
  async start(): Promise<void> {
    console.log('');
    console.log('╔══════════════════════════════════════════════════╗');
    console.log('║          🦅 鹰爪技能 · AI Agent 启动             ║');
    console.log('╠══════════════════════════════════════════════════╣');
    console.log(`║ 节点: ${this.config.alias}`);
    console.log(`║ 公钥: ${this.config.publicKey.slice(0, 32)}...`);
    console.log(`║ 中枢: ${this.config.httpUrl}`);
    console.log(`║ 技能: ${registry.getNames().join(', ')}`);
    console.log(`║ 轮询: ${this.config.pollInterval}s`);
    console.log('╚══════════════════════════════════════════════════╝');
    console.log('');

    // 创建工作目录
    await mkdir(this.workBaseDir, { recursive: true });

    // 1. 健康检查
    console.log('[AGENT] Checking Skynet hub health...');
    const healthy = await this.client.health();
    if (!healthy) {
      console.error('[AGENT] ❌ Skynet hub is not reachable. Please check SKYNET_HTTP_URL.');
      console.error('[AGENT] Will keep retrying...');
    } else {
      console.log('[AGENT] ✅ Skynet hub is healthy');
    }

    // 2. 注册节点
    console.log('[AGENT] Registering node...');
    const regResult = await this.client.register();
    if (regResult.success) {
      console.log(`[AGENT] ✅ Registered: ${regResult.data?.message}`);
    } else {
      // 可能已注册，不是致命错误
      console.log(`[AGENT] ⚠️ Register response: ${regResult.error}`);
    }

    // 3. 查询余额
    const balResult = await this.client.getBalance();
    if (balResult.success && balResult.data) {
      console.log(`[AGENT] 💰 Balance: ${balResult.data.balance} (frozen: ${balResult.data.frozen}, available: ${balResult.data.available})`);
      console.log(`[AGENT] ⭐ Reputation: ${balResult.data.reputation}`);
    }

    // 4. 连接 WebSocket
    this.setupWebSocket();

    // 5. 启动轮询
    this.running = true;
    this.startPolling();

    console.log('[AGENT] 🚀 Agent is running. Waiting for tasks...');
    console.log('');
  }

  /** 停止 Agent */
  async stop(): Promise<void> {
    console.log('[AGENT] Stopping...');
    this.running = false;

    if (this.pollTimer) {
      clearInterval(this.pollTimer);
      this.pollTimer = null;
    }

    this.client.disconnect();

    this.printStats();
    console.log('[AGENT] Stopped.');
  }

  /** 设置 WebSocket 事件监听 */
  private setupWebSocket(): void {
    this.client.connectWs();

    // 监听新任务发布
    this.client.on('task_posted', (event: WsEvent) => {
      console.log(`[WS] 📢 New task posted: ${event.task.id} — "${event.task.description.slice(0, 60)}..." reward=${event.task.reward}`);
      // 尝试抢单
      this.tryProcessTask(event.task);
    });

    // 监听任务被抢
    this.client.on('task_claimed', (event: WsEvent) => {
      if (event.task.claimer_key === this.config.publicKey) {
        console.log(`[WS] ✅ We claimed task: ${event.task.id}`);
      } else {
        console.log(`[WS] 👀 Task claimed by another node: ${event.task.id}`);
      }
    });

    // 监听任务完成
    this.client.on('task_submitted', (event: WsEvent) => {
      console.log(`[WS] 📤 Task submitted: ${event.task.id}`);
    });

    // 监听评审结果
    this.client.on('task_judged', (event: WsEvent) => {
      if (event.task.claimer_key === this.config.publicKey) {
        const verdict = event.task.judge_verdict;
        if (verdict === 'approve') {
          console.log(`[WS] 🎉 Our task APPROVED: ${event.task.id} (+${event.task.reward})`);
        } else {
          console.log(`[WS] 😞 Our task REJECTED: ${event.task.id} — ${event.task.judge_reason}`);
        }
      }
    });

    // 通配符：调试用
    // this.client.on('*', (event) => {
    //   console.log(`[WS] Event: ${event.type}`, event.task?.id);
    // });
  }

  /** 启动轮询 */
  private startPolling(): void {
    // 立即执行一次
    this.pollForTasks();

    this.pollTimer = setInterval(() => {
      this.pollForTasks();
    }, this.config.pollInterval * 1000);
  }

  /** 轮询查找可用任务 */
  private async pollForTasks(): Promise<void> {
    if (!this.running) return;
    if (this.processing) return; // 正在处理中，跳过

    try {
      const result = await this.client.listTasks('open', 20);

      if (!result.success || !result.data) return;

      const tasks = result.data.tasks;
      if (tasks.length === 0) return;

      console.log(`[POLL] Found ${tasks.length} open task(s)`);

      // 逐个检查是否有能处理的
      for (const task of tasks) {
        if (this.processing) break; // 已经在处理了
        await this.tryProcessTask(task);
      }
    } catch (err: any) {
      console.error(`[POLL] Error: ${err.message}`);
    }
  }

  /** 尝试处理一个任务 */
  private async tryProcessTask(task: Task): Promise<void> {
    // 防止并发
    if (this.processing) return;

    // 跳过自己发布的任务
    if (task.publisher_key === this.config.publicKey) return;

    // 跳过非 open 状态
    if (task.status !== 'open') return;

    // 检查是否有技能能处理
    const skill = registry.selectBest(task.description);
    if (!skill) {
      console.log(`[AGENT] No skill can handle task ${task.id}: "${task.description.slice(0, 50)}..."`);
      return;
    }

    console.log(`[AGENT] 🎯 Matched skill [${skill.name}] for task ${task.id}`);

    // 抢单
    this.processing = true;

    try {
      console.log(`[AGENT] Claiming task ${task.id}...`);
      const claimResult = await this.client.claimTask(task.id);

      if (!claimResult.success) {
        console.log(`[AGENT] ❌ Failed to claim: ${claimResult.error}`);
        return;
      }

      console.log(`[AGENT] ✅ Claimed task ${task.id}. Executing skill [${skill.name}]...`);

      // 构建执行上下文
      const context: SkillContext = {
        taskId: task.id,
        publisherKey: task.publisher_key,
        reward: task.reward,
        workDir: join(this.workBaseDir, task.id),
        timeout: parseInt(process.env.CODE_EXEC_TIMEOUT || '30', 10),
      };

      await mkdir(context.workDir, { recursive: true });

      // 执行技能
      const startTime = Date.now();
      let result: string;

      try {
        result = await skill.execute(task.description, context);
      } catch (execErr: any) {
        console.error(`[AGENT] ❌ Skill execution failed: ${execErr.message}`);
        result = `⚠️ 技能 [${skill.name}] 执行出错: ${execErr.message}\n\n尝试使用兜底方案...`;

        // 如果不是 llm-call 本身失败，尝试用 llm-call 兜底
        if (skill.name !== 'llm-call') {
          const fallbackSkill = registry.get('llm-call');
          if (fallbackSkill) {
            try {
              console.log('[AGENT] Falling back to llm-call...');
              result = await fallbackSkill.execute(task.description, context);
            } catch (fallbackErr: any) {
              result = `❌ 所有技能均执行失败。\n主技能 [${skill.name}]: ${execErr.message}\n兜底 [llm-call]: ${fallbackErr.message}`;
            }
          }
        }
      }

      const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
      console.log(`[AGENT] Skill executed in ${elapsed}s. Result length: ${result.length}`);

      // 提交结果
      console.log(`[AGENT] Submitting result for task ${task.id}...`);
      const submitResult = await this.client.submitTask(task.id, result);

      if (submitResult.success) {
        console.log(`[AGENT] ✅ Result submitted for task ${task.id}`);
        this.stats.tasksSucceeded++;
        this.stats.totalReward += task.reward;
      } else {
        console.error(`[AGENT] ❌ Submit failed: ${submitResult.error}`);
        this.stats.tasksFailed++;
      }

      this.stats.tasksProcessed++;

    } catch (err: any) {
      console.error(`[AGENT] ❌ Task processing error: ${err.message}`);
      this.stats.tasksFailed++;
      this.stats.tasksProcessed++;
    } finally {
      this.processing = false;
    }
  }

  /** 打印统计信息 */
  printStats(): void {
    const uptime = ((Date.now() - this.stats.startTime) / 1000 / 60).toFixed(1);
    console.log('');
    console.log('╔══════════════════════════════════════════════════╗');
    console.log('║          🦅 鹰爪技能 · 运行统计                  ║');
    console.log('╠══════════════════════════════════════════════════╣');
    console.log(`║ 运行时长:   ${uptime} 分钟`);
    console.log(`║ 处理任务:   ${this.stats.tasksProcessed}`);
    console.log(`║ 成功提交:   ${this.stats.tasksSucceeded}`);
    console.log(`║ 失败:       ${this.stats.tasksFailed}`);
    console.log(`║ 累计奖励:   ${this.stats.totalReward}`);
    console.log('╚══════════════════════════════════════════════════╝');
    console.log('');
  }

  /** 获取客户端实例（供外部调用） */
  getClient(): SkynetClient {
    return this.client;
  }
}
