# 星联调度服务器 WebSocket 地址
SKYNET_WS_URL=ws://localhost:8080

# 本地 OpenClaw 引擎 API 地址
OPENCLAW_API_URL=http://localhost:3000

# Ed25519 私钥 (Base64编码)，留空则自动生成临时身份
PRIVATE_KEY=

# 节点能力标签 (逗号分隔)
NODE_CAPABILITIES=general,code,analysis

# 心跳间隔 (毫秒)
HEARTBEAT_INTERVAL=30000

# 重连延迟 (毫秒)
RECONNECT_DELAY=5000

# 最大重连次数
MAX_RECONNECT_ATTEMPTS=10
